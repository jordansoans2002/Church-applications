<UserControl x:Class="Create_PPT_UI.View.Song"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Create_PPT_UI.View"
             mc:Ignorable="d"
             d:DesignHeight="90" d:DesignWidth="250">
    <DockPanel>
        <Button DockPanel.Dock="Right" Width="25" Height="25" Content="X" FontSize="10" Margin="0,0,2,0"/>
        <Grid Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <TextBlock Text="{Binding songName}" TextWrapping="Wrap" FontSize="14" FontWeight="Bold" />
            <TextBlock Grid.Row="1" Text="{Binding languages}" FontSize="12" Margin="5,2,0,0" />
            <TextBlock Grid.Row="2" Text="{Binding orientation}" FontSize="12" Margin="5,2,0,0" />
        </Grid>
    </DockPanel>
</UserControl>
